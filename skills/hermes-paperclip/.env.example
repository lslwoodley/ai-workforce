# Copy to .env and fill in your values. Never commit .env.

# Paperclip
PAPERCLIP_API_URL=http://localhost:3000
PAPERCLIP_API_KEY=your_paperclip_api_key

# Hermes
HERMES_MODEL=openrouter/anthropic/claude-3.5-sonnet
HERMES_SESSIONS_DIR=~/.hermes/sessions
HERMES_SKILLS_DIR=~/.hermes/skills

# Adapter behaviour
ADAPTER_HEARTBEAT_INTERVAL=30
ADAPTER_MAX_WORKERS=4

# MCP server (optional — for agent-to-agent calls)
MCP_SERVER_PORT=8765
MCP_SERVER_HOST=0.0.0.0
