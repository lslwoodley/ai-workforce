# ═══════════════════════════════════════════════════════════
# Hermes + Paperclip AI Workforce — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env.
# ═══════════════════════════════════════════════════════════

# ── Model Provider (at least one required) ──────────────────────────────────
# OpenRouter gives access to 200+ models via a single key (recommended)
OPENROUTER_API_KEY=sk-or-

# Or use providers directly:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Hermes Model ─────────────────────────────────────────────────────────────
# Which model Hermes workers use by default.
# Agents can switch per-session with: hermes model <provider/model>
HERMES_MODEL=openrouter/anthropic/claude-3.5-sonnet

# ── Paperclip ────────────────────────────────────────────────────────────────
# Port exposed on the host (change if 3100 is in use)
PAPERCLIP_PORT=3100
# Admin password for the Paperclip UI
PAPERCLIP_ADMIN_PASSWORD=changeme
# API key for the adapter and MCP server to authenticate with Paperclip
# Leave empty to disable auth (fine for local-only setups)
PAPERCLIP_API_KEY=

# ── Adapter Behaviour ────────────────────────────────────────────────────────
# How often the adapter polls Paperclip for new tasks (seconds)
ADAPTER_HEARTBEAT_INTERVAL=30
# Max parallel Hermes threads per worker container (up to 8)
ADAPTER_MAX_WORKERS=4

# ── MCP Server ───────────────────────────────────────────────────────────────
# Port for agent-to-agent MCP calls
MCP_SERVER_PORT=8765
