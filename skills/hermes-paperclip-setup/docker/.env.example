# ═══════════════════════════════════════════════════════════════════════════════
# Hermes + Paperclip AI Workforce — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── OpenRouter (recommended primary — 200+ models, free tier available) ────────
# Pool strategy: round_robin across all healthy keys
# Free model default: openrouter/nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_API_KEY=sk-or-
OPENROUTER_API_KEY_2=          # optional backup key — rotated automatically on 429/402
OPENROUTER_API_KEY_3=          # optional third key

# ── Anthropic (optional — pairs with Claude Code OAuth in Paperclip) ───────────
# Pool strategy: least_used (protects quota; Claude Code OAuth auto-discovered)
# Note: run `docker compose exec paperclip claude auth login` to add OAuth too
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_2=           # optional backup

# ── OpenAI / GPT (optional fallback) ──────────────────────────────────────────
# Pool strategy: fill_first
OPENAI_API_KEY=
OPENAI_API_KEY_2=

# ── Google Gemini (optional fallback) ─────────────────────────────────────────
# Pool strategy: round_robin
# Configured as custom OpenAI-compatible endpoint automatically
GOOGLE_API_KEY=
GOOGLE_API_KEY_2=
GOOGLE_MODEL=gemini-2.0-flash-lite   # or gemini-1.5-pro, gemini-2.0-flash, etc.

# ── LM Studio (local Windows GPU — recommended fallback) ──────────────────────
# LM Studio runs on your Windows host and exposes an OpenAI-compatible API.
# Docker containers reach it via host.docker.internal:1234 (default LM Studio port).
# Set LM_STUDIO_MODEL to the exact model string shown in LM Studio's model selector.
# Leave LM_STUDIO_MODEL empty to disable.
#
# Examples:
#   kimi-k2-instruct                           ← Kimi K2 reasoning model
#   lmstudio-community/Kimi-K2-Instruct-GGUF  ← full GGUF model ID if required
#   qwen2.5-coder-32b-instruct                 ← code-heavy tasks
LM_STUDIO_BASE_URL=http://host.docker.internal:1234
LM_STUDIO_MODEL=qwen3-4b-kimi2.5-reasoning-distilled@q4_k_m                     # paste the model ID from LM Studio here

# ── Ollama (local LLMs, zero cost — alternative to LM Studio) ─────────────────
# Leave OLLAMA_BASE_URL empty to skip.
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2                # any model you have pulled locally

# ── Hermes model (default agent model) ────────────────────────────────────────
# Primary model used when no failback is needed.
# Pool failback order: OpenRouter → LM Studio GPU → Ollama → OpenAI → Gemini
# Examples:
#   openrouter/nvidia/nemotron-3-super-120b-a12b:free  ← free, capable (default)
#   openrouter/google/gemini-2.0-flash-lite:free       ← fast, free
#   openrouter/anthropic/claude-3.5-sonnet             ← smart, paid
HERMES_MODEL=openrouter/nvidia/nemotron-3-super-120b-a12b:free

# ── Paperclip ─────────────────────────────────────────────────────────────────
PAPERCLIP_PORT=3100
PAPERCLIP_ADMIN_PASSWORD=changeme
PAPERCLIP_API_KEY=
# Required for Paperclip auth — must be 32+ characters
BETTER_AUTH_SECRET=ai-workforce-paperclip-secret-change-in-prod-32x

# ── Paperclip version ─────────────────────────────────────────────────────────
PAPERCLIP_VERSION=master

# ── Hermes Gateway ────────────────────────────────────────────────────────────
# Port for the Hermes OpenAI-compatible API server
# POST http://localhost:8642/v1/chat/completions
# GET  http://localhost:8642/v1/models
HERMES_GATEWAY_PORT=8642

# Messaging platform tokens (optional — enables Telegram/Discord/Slack bridges)
# Add your bot tokens to activate those platforms in the gateway
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=

# ── DeepSeek (optional — cheap cloud reasoning) ──────────────────────────────
# deepseek-reasoner = thinking model; deepseek-chat = faster/cheaper
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-reasoner

# ── Hermes SIGTERM grace period ───────────────────────────────────────────────
# Seconds hermes waits after SIGTERM before raising KeyboardInterrupt.
# 3600 = survive any in-flight agent task. 0 = exit immediately.
HERMES_SIGTERM_GRACE=3600

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_SERVER_PORT=8765

# ── Agent git workspace (optional — enables agent branch commits & PRs) ────────
AGENT_GIT_TOKEN=               # GitHub fine-grained PAT with repo contents write
AGENT_REPO_URL=                # e.g. https://github.com/lslwoodley/aiworkforce
AGENT_GIT_USER=ai-workforce-bot
AGENT_GIT_EMAIL=agents@localhost
AGENT_WORKSPACE_MOUNT=/workspace
